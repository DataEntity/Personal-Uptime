# UI 开发：mock（不需要 API）
# 联调：live
# 日常：auto（fetch 失败回退 mock）
NEXT_PUBLIC_DATA_MODE=mock

# live / auto 模式下的 API 地址（推薦使用 Tailscale IP 或其他加密通道）, 端口可自定(例如3000)
NEXT_PUBLIC_STATUS_API_URL=http://<tailscale-ip>:<port>/status

# commits log 代理端点（后端 GET /commits/log，15 分钟轮询）
# NEXT_PUBLIC_COMMITS_API_URL=http://<tailscale-ip>:<port>/commits/log
